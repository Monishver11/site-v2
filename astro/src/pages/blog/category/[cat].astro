---
import { getCollection } from "astro:content";
import Base from "../../../layouts/Base.astro";
import BlogTabs from "../../../components/BlogTabs.astro";
import CategoryNav from "../../../components/CategoryNav.astro";
import { CATEGORIES } from "../../../lib/categories";

export async function getStaticPaths() {
  return CATEGORIES.map((cat) => ({
    params: { cat: cat.slug },
    props: { category: cat },
  }));
}

const { category } = Astro.props;

const posts = (
  await getCollection(
    "blog",
    ({ data }) => !data.draft && data.category === category.label
  )
).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "2-digit",
    timeZone: "UTC",
  });
---

<Base
  title={`${category.label} · Monishver Chandrasekaran`}
  description={`Blog posts in ${category.label}, in reading order.`}
>
  <section class="head">
    <h1>Blog</h1>
    <p class="sub">Concepts, notes, and intuitions</p>
    <hr class="flourish" />
  </section>
  <CategoryNav active={category.slug} />
  <BlogTabs active="written" />
  <section class="listing">
    <h2>{category.label}</h2>
    <p class="order-note">{posts.length} {posts.length === 1 ? "post" : "posts"}</p>
    <ol>
      {
        posts.map((post) => (
          <li>
            <span class="date">{fmt(post.data.date)}</span>
            <a href={`/blog/${post.id}/`}>{post.data.title}</a>
          </li>
        ))
      }
    </ol>
  </section>
</Base>

<style>
  .head {
    text-align: center;
    padding-top: 3rem;
  }
  .head h1 {
    font-size: 1.5rem;
    font-weight: 500;
    margin: 0 0 0.35rem;
  }
  .sub {
    font-style: italic;
    font-size: 0.92rem;
    color: var(--text-secondary);
    margin: 0;
  }
  .flourish {
    border: none;
    border-top: 1px solid var(--border-strong);
    width: 5rem;
    margin: 1.6rem auto 2rem;
  }
  .listing h2 {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 0.5rem 0 0.2rem;
  }
  .order-note {
    font-size: 0.82rem;
    font-style: italic;
    color: var(--text-muted);
    margin: 0 0 1rem;
  }
  .listing ol {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .listing li {
    display: flex;
    gap: 1.1rem;
    padding: 0.32rem 0;
    align-items: baseline;
  }
  .date {
    font-size: 0.82rem;
    color: var(--text-muted);
    min-width: 6.6rem;
    font-variant-numeric: tabular-nums;
  }
  .listing a {
    color: var(--text);
    text-decoration: none;
  }
  .listing a:hover {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
