---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import BlogTabs from "../../components/BlogTabs.astro";
import CategoryNav from "../../components/CategoryNav.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const byYear = new Map<number, typeof posts>();
for (const post of posts) {
  const y = post.data.date.getFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(post);
}
const years = [...byYear.keys()].sort((a, b) => b - a);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", {
    month: "short",
    day: "2-digit",
    timeZone: "UTC",
  });
---

<Base title="Blog · Monishver Chandrasekaran" description="Technical deep dives: ML theory, GPU kernels, big data systems.">
  <section class="head">
    <h1>Blog</h1>
    <p class="sub">Concepts, notes, and intuitions</p>
    <hr class="flourish" />
  </section>
  <CategoryNav />
  <BlogTabs active="written" />
  {
    years.map((year) => (
      <section class="year">
        <h2>{year}</h2>
        <ul>
          {byYear.get(year)!.map((post) => (
            <li>
              <span class="date">{fmt(post.data.date)}</span>
              <span class="entry">
                <a href={`/blog/${post.id}/`}>{post.data.title}</a>
                <span class="cat">{post.data.category}</span>
              </span>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</Base>

<style>
  .head {
    text-align: center;
    padding-top: 3rem;
  }
  .head h1 {
    font-size: 1.5rem;
    font-weight: 500;
    margin: 0 0 0.35rem;
  }
  .sub {
    font-style: italic;
    font-size: 0.92rem;
    color: var(--text-secondary);
    margin: 0;
  }
  .flourish {
    border: none;
    border-top: 1px solid var(--border-strong);
    width: 5rem;
    margin: 1.6rem auto 2rem;
  }
  .year h2 {
    font-size: 1.05rem;
    font-weight: 600;
    margin: 1.8rem 0 0.7rem;
  }
  .year ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .year li {
    display: flex;
    gap: 1.1rem;
    padding: 0.32rem 0;
    align-items: baseline;
  }
  .date {
    font-size: 0.82rem;
    color: var(--text-muted);
    min-width: 3.4rem;
    font-variant-numeric: tabular-nums;
  }
  .entry a {
    color: var(--text);
    text-decoration: none;
  }
  .entry a:hover {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .cat {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-style: italic;
    margin-left: 0.5rem;
  }
</style>
