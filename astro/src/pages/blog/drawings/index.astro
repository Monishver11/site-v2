---
import Base from "../../../layouts/Base.astro";
import BlogTabs from "../../../components/BlogTabs.astro";
---

<Base title="Excalidraw · Monishver Chandrasekaran" description="Excalidraw illustrations from my blog posts.">
  <section class="head">
    <h1>Blog</h1>
    <p class="sub">Concepts, notes, and intuitions</p>
    <hr class="flourish" />
  </section>
  <BlogTabs active="drawings" />
  <p class="empty">
    Excalidraw illustrations will live here soon, drawn from first principles
    for upcoming posts.
  </p>
</Base>

<style>
  .head {
    text-align: center;
    padding-top: 3rem;
  }
  .head h1 {
    font-size: 1.5rem;
    font-weight: 500;
    margin: 0 0 0.35rem;
  }
  .sub {
    font-style: italic;
    font-size: 0.92rem;
    color: var(--text-secondary);
    margin: 0;
  }
  .flourish {
    border: none;
    border-top: 1px solid var(--border-strong);
    width: 5rem;
    margin: 1.6rem auto 2rem;
  }
  .empty {
    text-align: center;
    font-style: italic;
    color: var(--text-muted);
    padding: 2rem 0 4rem;
  }
</style>
