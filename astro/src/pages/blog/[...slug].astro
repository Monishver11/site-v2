---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import Subscribe from "../../components/Subscribe.astro";
import Giscus from "../../components/Giscus.astro";
import { chapterFor, prevNext } from "../../lib/book";
import "katex/dist/katex.min.css";
import "../../styles/post.css";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const titleOf = new Map(posts.map((p) => [p.id.toLowerCase(), p.data.title]));
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, titleOf: Object.fromEntries(titleOf) },
  }));
}

const { post, titleOf } = Astro.props;
const { Content } = await render(post);

// If this post is a book chapter, surface its place in the book.
const chapter = chapterFor(post.id);
const { prev, next } = chapter ? prevNext(post.id) : { prev: null, next: null };
const partLabel = chapter
  ? chapter.chapterNumber
    ? `${chapter.partName} · Chapter ${chapter.chapterNumber}`
    : chapter.partName
  : null;

const dateStr = post.data.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
});
---

<Base title={post.data.title} description={post.data.description}>
  <article>
    <header class="post-header">
      {partLabel && (
        <p class="book-crumb">
          <a href="/book/">Book</a> &middot; {partLabel}
        </p>
      )}
      <h1>{post.data.title}</h1>
      <p class="meta">
        {dateStr} &middot; {post.data.category}
        {post.data.tags.length > 0 && (
          <span class="tags">
            &middot; {post.data.tags.join(", ")}
          </span>
        )}
      </p>
      <hr class="flourish" />
    </header>
    <div class="prose">
      <Content />
    </div>
    {chapter && (
      <nav class="chapter-nav">
        {prev ? (
          <a class="prev" href={`/blog/${prev.slug}/`}>
            <span class="dir">Previous</span>
            <span class="ch-title">{titleOf[prev.slug.toLowerCase()]}</span>
          </a>
        ) : (
          <span />
        )}
        {next ? (
          <a class="next" href={`/blog/${next.slug}/`}>
            <span class="dir">Next</span>
            <span class="ch-title">{titleOf[next.slug.toLowerCase()]}</span>
          </a>
        ) : (
          <span />
        )}
      </nav>
    )}
    <Subscribe />
    <Giscus />
  </article>
</Base>

<style>
  .post-header {
    text-align: center;
    padding-top: 3rem;
  }
  .post-header h1 {
    font-size: 1.55rem;
    font-weight: 500;
    line-height: 1.3;
    margin: 0 0 0.5rem;
  }
  .book-crumb {
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.6rem;
  }
  .book-crumb a {
    color: inherit;
    text-decoration: none;
  }
  .book-crumb a:hover {
    text-decoration: underline;
  }
  .meta {
    font-style: italic;
    font-size: 0.88rem;
    color: var(--text-secondary);
    margin: 0;
  }
  .chapter-nav {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    margin: 3rem 0 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-strong);
  }
  .chapter-nav a {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    text-decoration: none;
    max-width: 45%;
  }
  .chapter-nav .next {
    text-align: right;
    margin-left: auto;
  }
  .chapter-nav .dir {
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }
  .chapter-nav .ch-title {
    color: var(--accent);
  }
  .chapter-nav a:hover .ch-title {
    text-decoration: underline;
  }
  .flourish {
    border: none;
    border-top: 1px solid var(--border-strong);
    width: 5rem;
    margin: 1.6rem auto 2.4rem;
  }
</style>
