---
/* Comments via giscus, same repo + category as the current site so existing
   discussions (mapped by title) carry over. */
---

<section class="comments">
  <hr class="rule" />
  <script
    src="https://giscus.app/client.js"
    data-repo="Monishver11/monishver11.github.io"
    data-repo-id="R_kgDONe9Wkw"
    data-category="General"
    data-category-id="DIC_kwDONe9Wk84Cp-bh"
    data-mapping="title"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="bottom"
    data-theme="light"
    data-lang="en"
    crossorigin="anonymous"
    async></script>
</section>

<style>
  .comments {
    margin-top: 3rem;
  }
  .rule {
    border: none;
    border-top: 1px solid var(--border);
    margin: 0 0 2rem;
  }
</style>
